{
  "name": "devai",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "docker compose up -d db && concurrently -n frontend,backend -c cyan,green \"npm run dev:frontend\" \"npm run dev:backend\"",
    "vercel-build": "npm run build --workspace=frontend",
    "dev:frontend": "npm run dev --workspace=frontend",
    "dev:backend": "npm run start:dev --workspace=backend",
    "build:frontend": "npm run build --workspace=frontend",
    "build:backend": "npm run build --workspace=backend",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test:all",
    "test:all": "npm run test:unit && npm run test:integration && npm run test:e2e",
    "test:e2e": "npm run db:reset --workspace=backend && npm run test --workspace=frontend -- --workers=1",
    "test:unit": "npm run test --workspace=backend -- --coverage",
    "test:integration": "npm run test:e2e --workspace=backend -- --coverage"
  },
  "devDependencies": {
    "@omniroute/opencode-provider": "^0.1.0",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/jest-runner": "^9.6.1",
    "@stryker-mutator/typescript-checker": "^9.6.1",
    "concurrently": "^10.0.3",
    "eslint-plugin-sonarjs": "^4.1.0"
  }
}